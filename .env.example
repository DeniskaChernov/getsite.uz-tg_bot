# === Telegram ===
# Токен бота от @BotFather. НИКОГДА не коммитить в git.
BOT_TOKEN=123456789:REPLACE_ME

# Приватная админ-группа для карточек лидов (chat_id, отрицательное число для групп)
ADMIN_CHAT_ID=-1001234567890

# Allowlist админов по user_id (не по username!), через запятую
ADMIN_IDS=11111111,22222222

# === Webhook ===
# Режим: webhook (продакшен) или polling (локальная разработка)
MODE=webhook

# Публичный HTTPS-адрес сервиса, без завершающего слэша
WEBHOOK_BASE_URL=https://bot.example.com

# Секрет вебхука: случайные 64+ бита, например `openssl rand -hex 16`
WEBHOOK_SECRET=REPLACE_WITH_RANDOM_HEX

# Неугадываемая часть пути вебхука, например `openssl rand -hex 8`
WEBHOOK_PATH_SECRET=REPLACE_WITH_RANDOM_HEX

# Порт HTTP-сервера (Railway подставляет свой через PORT)
PORT=8080

# === LLM ===
# Любой OpenAI-совместимый API (OpenAI, OpenRouter, ...)
LLM_API_KEY=sk-REPLACE_ME
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# === Хранилище ===
# Продакшен: Postgres (общая БД с сайтом, таблицы bot_*). На Railway задаётся автоматически.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Локально без DATABASE_URL используется SQLite:
DB_PATH=data/bot.db
